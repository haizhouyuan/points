# Points项目环境变量配置模板

# 运行环境
NODE_ENV=production

# 应用端口配置
APP_PORT=5001

# Docker镜像标签配置
APP_TAG=sha-latest

# 未来扩展：前端API配置（当与后端服务对接时使用）
# VITE_API_URL=http://localhost:5000
# VITE_API_TIMEOUT=10000

# 开发模式配置
# VITE_DEBUG=false
# VITE_LOG_LEVEL=info

# 部署相关配置（仅部署时需要，勿提交真实值）
# PROD_HOST=your-server-ip
# PROD_USER=your-username
# PROD_SSH_KEY=your-ssh-private-key
# GHCR_PAT=your-github-container-registry-token