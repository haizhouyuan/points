# 服务器配置
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# 数据库配置
MONGODB_URI=mongodb://localhost:27017/summer_vacation
MONGODB_TEST_URI=mongodb://localhost:27017/summer_vacation_test

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,video/mp4,application/pdf

# 邮件配置
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password
FROM_EMAIL=noreply@summervacation.app
FROM_NAME=Summer Vacation Planning

# 外部服务配置
# 头像存储
AVATAR_STORAGE=local
# AWS S3 (可选)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=summer-vacation-files

# API配置
API_PREFIX=/api/v1
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# 安全配置
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=6
CORS_ORIGIN=http://localhost:3000

# 游戏化配置
DEFAULT_DAILY_GOAL=100
XP_PER_LEVEL_MULTIPLIER=100
MAX_LIVES=5
LIFE_RESTORE_MINUTES=30

# 通知配置
NOTIFICATION_TTL_DAYS=30
MAX_NOTIFICATIONS_PER_USER=1000

# 缓存配置
CACHE_TTL_SECONDS=300
LEADERBOARD_CACHE_TTL=3600

# 开发调试
DEBUG=summer-vacation:*
LOG_LEVEL=info