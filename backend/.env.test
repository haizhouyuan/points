# 测试环境配置
NODE_ENV=test
PORT=5001
HOST=localhost

# 数据库配置
MONGODB_URI=mongodb://localhost:27017/summer_vacation_test
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1

# JWT配置
JWT_SECRET=test-jwt-secret-key-for-testing-only
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# 测试配置
LOG_LEVEL=error
BCRYPT_ROUNDS=4

# 缓存配置
CACHE_TTL_SECONDS=60